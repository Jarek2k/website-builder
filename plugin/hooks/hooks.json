{
  "description": "website-builder verification guard: tracks web-surface edits and blocks Stop once if verify-composition has not run since the last edit. Disable with WEBSITE_BUILDER_GUARD=off.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-track.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-guard.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
